# export ZSH_AUTOSUGGEST_STRATEGY=(
#     history
#     completion
# )
# bindkey '^$' autosuggest-accept
# bindkey '\t' forward-word

# zsh-autosuggestions
# default value is https://github.com/zsh-users/zsh-autosuggestions/blob/master/src/config.zsh
# Widgets that accept the entire suggestion
ZSH_AUTOSUGGEST_ACCEPT_WIDGETS=(
    # forward-char
    end-of-line
    vi-forward-char
    vi-end-of-line
    vi-add-eol
)


# Widgets that accept the suggestion as far as the cursor moves

ZSH_AUTOSUGGEST_PARTIAL_ACCEPT_WIDGETS=(
    forward-char
    forward-word
    emacs-forward-word
    vi-forward-word
    vi-forward-word-end
    vi-forward-blank-word
    vi-forward-blank-word-end
    vi-find-next-char
    vi-find-next-char-skip
)

# Machine-injected environment, sourced last so it overrides.
# Cluster/cloud nodes (e.g. AWS HyperPod) write ~/.jc_env.sh with per-node
# CUDA/NVIDIA/AWS vars and secrets. That file is machine-specific and holds
# credentials, so it stays OUT of the dotfiles repo — only this hook is tracked.
if [ -r "$HOME/.jc_env.sh" ] && [ -f "$HOME/.jc_env.sh" ]; then
	. "$HOME/.jc_env.sh"
fi
